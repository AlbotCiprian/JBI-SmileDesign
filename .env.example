# =====================================================
# JBI Smile Design — Environment Variables (template)
# =====================================================
# Copiază acest fișier ca .env.local și completează cheile pe măsură
# ce avansăm în faze. Niciuna nu e necesară pentru landing page-ul static.

# ---------- FAZA 2: Baza de date (Neon PostgreSQL) ----------
# Obține de la https://neon.tech → New Project → Connection string (Pooled)
DATABASE_URL=""

# ---------- FAZA 2: Email (Resend) ----------
# Obține de la https://resend.com → API Keys
RESEND_API_KEY=""
APPOINTMENT_TO_EMAIL="smiledesignsrl@yahoo.com"

# ---------- FAZA 3: Anti-spam (Google reCAPTCHA v3) ----------
# Obține de la https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# ---------- FAZA 4: Admin Panel (NextAuth) ----------
# Generează NEXTAUTH_SECRET cu: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@jbismiledesign.md"
ADMIN_PASSWORD="change-me-on-seed"

# ---------- FAZA 5: Google Calendar (opțional) ----------
# Service Account din Google Cloud Console
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_CALENDAR_ID=""
